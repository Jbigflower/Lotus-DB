# Lotus-DB Backend Environment Configuration
# 复制此文件为 .env 并根据实际环境修改配置

# ===== 应用配置 =====
APP_NAME=Lotus-DB Backend
APP_VERSION=1.0.0
APP_DESCRIPTION=Lotus-DB 后端服务
DEBUG=true
ENVIRONMENT=development
PREFERRED_LANGUAGE=zh-CN
SERVER_NAME=Lotus-Server

# ===== 服务器配置 =====
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=info

# ===== 数据库配置 =====
# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=lotus_db
# MONGO_USERNAME=
# MONGO_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Chroma
CHROMA_HOST=localhost
CHROMA_PORT=18001
CHROMA_PERSIST_DIRECTORY=./data/chroma_data
CHROMA_COLLECTION_NAME=lotus_vectors

# LanceDB
LANCEDB_PATH=./data/lance_data
LANCE_DB_NAME=lotus_db

# ===== 媒体路径配置 =====
LIBRARY_PREFIX=./data/media/library
USER_PREFIX=./data/media/user
OTHER_PREFIX=./data/media/others

# 文件大小限制
MAX_FILE_SIZE=104857600
MAX_VIDEO_SIZE=5368709120

# ===== Nginx 配置 =====
NGINX_STATIC_BASE_URL=http://localhost:8080
NGINX_LIBRARY_LOCATION=/static/library
NGINX_USER_LOCATION=/static/user
SECURE_LINK_SECRET=change-me

# ===== 插件配置 =====
# OMDB API
OMDB_API_KEY=your_omdb_api_key

# ===== LLM 配置 =====
# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
OLLAMA_EMBEDDING_DIM=768
